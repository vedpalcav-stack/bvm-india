const router = require("express").Router();
const controller = require("./dispatch.controller");

router.get("/", controller.getDispatch);
router.post("/", controller.createDispatch);

module.exports = router;

exports.getDispatch = async (req, res) => {
  res.json([]);
};

exports.createDispatch = async (req, res) => {
  res.json({
    success: true,
    message: "Dispatch created"
  });
};
module.exports = {};
module.exports = {};
